# =============================================================================
# Combined mode (nginx front door on :8080).
# =============================================================================
# Copy to .env.combined. `make dev-combined` loads this file via
# `set -a; . file; set +a` so values with spaces, `#`, `$`, or quotes MUST be
# quoted. After this file is sourced, config.py's load_dotenv() fills in
# everything else from .env without overwriting — keep your real OAuth
# secrets, BOND_MCP_CONFIG, etc. in .env, and put only OVERRIDES here.
#
# OAuth callbacks are NOT changed: they keep going to :8002 (user-login) and
# :8000 (MCP). Cookies set on :8002 cross over to :8080 for the app — browser
# cookies on localhost aren't port-scoped. See docs/local-dev-combined-mode.md.
# =============================================================================

# Where bond-ai redirects the browser after a successful login. Points at the
# front door so the user lands on the app (not the Flutter dev server :3002).
JWT_REDIRECT_URI="http://localhost:8080"

# Allow the front-door origin for CORS / Origin checks. Keep the other entries
# so split mode and direct :8002 access still work.
CORS_ALLOWED_ORIGINS="http://localhost,http://localhost:8080,http://localhost:3002"

# REQUIRED for HTTP local dev. bondable/rest/routers/auth.py defaults
# COOKIE_SECURE=true, which causes the browser to silently drop the
# bond_session and bond_csrf cookies sent over HTTP. Symptoms without this:
# login appears to succeed (browser sees the redirect) but the next request
# has no session and the UI thinks you're logged out, with no error anywhere.
# Production stays secure=true by default.
COOKIE_SECURE=false
