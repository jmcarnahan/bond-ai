# =============================================================================
# Combined mode (nginx front door on :8080).
# =============================================================================
# Copy to .env.combined and fill in the real values (OAuth secrets, etc.).
# `make dev-combined` loads this file via `set -a; . file; set +a` so values
# with spaces, `#`, `$`, or quotes MUST be quoted.
#
# See docs/local-dev-combined-mode.md for context.
# =============================================================================

# Triggers the BOND_MCP_CONFIG runtime rewrite in config.py: oauth_config.redirect_uri
# values pointing at localhost:8000 or 127.0.0.1:8000 are rewritten to use this URL.
# Lets you reuse your normal split-mode BOND_MCP_CONFIG unchanged.
BOND_FRONT_DOOR_URL=http://localhost:8080

# OAuth callbacks now go through nginx instead of hitting bond-ai on :8002 directly.
GOOGLE_AUTH_REDIRECT_URI="http://localhost:8080/auth/google/callback"
OKTA_REDIRECT_URI="http://localhost:8080/auth/okta/callback"
COGNITO_REDIRECT_URI="http://localhost:8080/auth/cognito/callback"

# Where bond-ai redirects the browser after a successful login. Same-origin as
# the front door so the auth cookie is sent on the next request.
JWT_REDIRECT_URI="http://localhost:8080"

# Browser origins allowed by CORS. Front-door origin must be in the list.
CORS_ALLOWED_ORIGINS="http://localhost,http://localhost:8080,http://localhost:3002"

# REQUIRED for HTTP local dev. bondable/rest/routers/auth.py defaults
# COOKIE_SECURE=true, which causes the browser to silently drop the bond_session
# and bond_csrf cookies sent over HTTP. Symptoms without this: login appears to
# succeed (browser sees the redirect) but the next request has no session and
# the UI thinks you're logged out, with no error anywhere. Production stays
# secure=true by default.
COOKIE_SECURE=false

# --- .env still loads ---------------------------------------------------------
# The Makefile exports .env.combined values into the process env BEFORE uvicorn
# starts. config.py then calls load_dotenv() which fills in any var not already
# set from .env (dotenv does not overwrite). Net: keep your normal .env intact
# and only put the OVERRIDES above — secrets, BOND_MCP_CONFIG, JWT_SECRET_KEY,
# etc. stay in .env untouched.
