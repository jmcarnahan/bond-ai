# =============================================================================
# Combined mode (nginx front door on :8000).
# =============================================================================
# Copy to .env.combined. `make dev-combined` loads this file via
# `set -a; . file; set +a`, then uvicorn starts and config.py's load_dotenv()
# fills in everything else from .env without overwriting — keep your real
# OAuth secrets, BOND_MCP_CONFIG, etc. in .env, and put only OVERRIDES here.
#
# Front door :8000 matches the OAuth callback URLs already registered with
# providers (Google / Okta / Cognito for user-login; Atlassian / GitHub /
# Microsoft for MCP), so no provider console changes are needed. nginx
# routes /auth/* and /login/* to bond-ai :8002 and /connections/* to
# bond-mcps :18000 (bond-mcps moves off :8000 in combined mode so nginx
# can take the front door — see ../bond-mcps's `make dev-combined`).
#
# See docs/local-dev-combined-mode.md for the full architecture.
# =============================================================================

# OAuth user-login callbacks (point at the front door :8000 — matches what's
# registered in Google / Okta / Cognito consoles). nginx forwards /auth/* to
# bond-ai :8002.
GOOGLE_AUTH_REDIRECT_URI="http://localhost:8000/auth/google/callback"
OKTA_REDIRECT_URI="http://localhost:8000/auth/okta/callback"
COGNITO_REDIRECT_URI="http://localhost:8000/auth/cognito/callback"

# Where bond-ai sends the browser after a successful login. Points at the
# front door so the user lands on the app (not the Flutter dev server :3002,
# not the backend :8002).
JWT_REDIRECT_URI="http://localhost:8000"

# Allow the front-door origin for CORS / Origin checks.
CORS_ALLOWED_ORIGINS="http://localhost,http://localhost:8000,http://localhost:3002"

# REQUIRED for HTTP local dev. bondable/rest/routers/auth.py defaults
# COOKIE_SECURE=true, which causes the browser to silently drop the
# bond_session and bond_csrf cookies sent over HTTP. Symptoms without this:
# login appears to succeed (browser sees the redirect) but the next request
# has no session and the UI thinks you're logged out, with no error anywhere.
# Production stays secure=true by default.
COOKIE_SECURE=false
