FROM public.ecr.aws/docker/library/python:3.12-slim

WORKDIR /app

# Install system dependencies (including nginx and supervisor)
RUN apt-get update && apt-get install -y \
    gcc \
    postgresql-client \
    nginx \
    supervisor \
    && rm -rf /var/lib/apt/lists/*

# Install poetry
RUN pip install poetry==2.1.3

# Copy dependency files
COPY pyproject.toml poetry.lock ./

# Install dependencies, then remove gcc (only needed for building C extensions)
# POETRY_HTTP_TIMEOUT raised from default 15s to handle slow Docker Desktop buildx
# networking under QEMU emulation (Docker Desktop 4.68+ on Apple Silicon)
# Docker Desktop 4.68+ throttles concurrent connections under QEMU emulation;
# sequential downloads (max-workers=1) prevent connection pool exhaustion
ENV POETRY_HTTP_TIMEOUT=300
ENV POETRY_REQUESTS_TIMEOUT=300
RUN poetry config virtualenvs.create false && \
    poetry config installer.max-workers 1 && \
    poetry install --only main --no-interaction --no-ansi --no-root && \
    apt-get purge -y gcc

# Copy application code
COPY bondable/ ./bondable/

# Copy pre-built Flutter web files
COPY flutterui/build/web /usr/share/nginx/html

# Copy nginx and supervisord configs
COPY deployment/nginx-combined.conf /etc/nginx/conf.d/default.conf
COPY deployment/supervisord.conf /etc/supervisor/conf.d/bond-ai.conf

# Remove default nginx site config (Debian/Ubuntu uses sites-enabled)
RUN rm -f /etc/nginx/sites-enabled/default

# Create app logs directory
RUN mkdir -p /app/logs

# Set environment variables
ENV PYTHONUNBUFFERED=1
ENV PORT=8080
ENV BOND_PROVIDER_CLASS=bondable.bond.providers.bedrock.BedrockProvider.BedrockProvider

# Expose port 8080 (Nginx)
EXPOSE 8080

# Start supervisord (manages both nginx and uvicorn)
CMD ["supervisord", "-n", "-c", "/etc/supervisor/conf.d/bond-ai.conf"]
